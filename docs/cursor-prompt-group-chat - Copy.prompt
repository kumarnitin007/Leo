## STEP 6 — Wire real-time Supabase messaging

Replace the `useState(INIT_MESSAGES)` and the send function with
Supabase real-time. Add the following hooks inside the component
(after the existing state declarations):

### 6a — Load messages on mount
```tsx
useEffect(() => {
  if (!groupId) return

  // Load last 100 messages
  supabase
    .from('group_finance_messages')
    .select('*')
    .eq('group_id', groupId)
    .order('created_at', { ascending: true })
    .limit(100)
    .then(({ data }) => {
      if (data) {
        setMessages(data.map(transformMessage))
      }
    })
}, [groupId])
```

### 6b — Subscribe to real-time new messages
```tsx
useEffect(() => {
  if (!groupId) return

  const channel = supabase
    .channel(`group-chat-${groupId}`)
    .on(
      'postgres_changes',
      {
        event: 'INSERT',
        schema: 'public',
        table: 'group_finance_messages',
        filter: `group_id=eq.${groupId}`,
      },
      (payload) => {
        setMessages(prev => [...prev, transformMessage(payload.new)])
      }
    )
    .subscribe()

  return () => { supabase.removeChannel(channel) }
}, [groupId])
```

### 6c — Transform helper (add near the top of the component)
```tsx
function transformMessage(row: any): GroupFinanceMessage {
  return {
    id: row.id,
    group_id: row.group_id,
    sender_id: row.sender_id,
    sender_name: row.sender_name,
    type: row.type,
    text: row.text || '',
    payload: row.payload || {},
    created_at: row.created_at,
    // Map payload fields to the shape the UI expects
    fd:    row.payload?.fd,
    alert: row.payload?.alert,
    doc:   row.payload?.doc,
  }
}
```

### 6d — Replace the sendMessage function
```tsx
async function sendMessage() {
  const text = inputText.trim()
  if (!text && !attachment) return

  const baseText = text || (
    attachment?.type === 'fd'    ? 'Sharing FD details:' :
    attachment?.type === 'alert' ? 'Maturity alert for the group:' :
    'Sharing document:'
  )

  const payload: Record<string, any> = {}
  if (attachment?.type === 'fd')    payload.fd    = attachment.data
  if (attachment?.type === 'alert') payload.alert = attachment.data
  if (attachment?.type === 'doc')   payload.doc   = attachment.data

  const { error } = await supabase
    .from('group_finance_messages')
    .insert({
      group_id:    groupId,
      sender_id:   currentUser.id,
      sender_name: currentUser.name,
      type:        attachment?.type || 'text',
      text:        baseText,
      payload:     Object.keys(payload).length > 0 ? payload : null,
    })

  if (!error) {
    setInputText('')
    setAttachment(null)
  } else {
    console.error('Failed to send message:', error)
  }
}
```

