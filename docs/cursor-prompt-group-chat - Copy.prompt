## STEP 3 — Create Supabase tables

Run this SQL in the Supabase SQL editor. Run each block separately.

### 3a — Messages table
```sql
create table if not exists group_finance_messages (
  id           uuid default gen_random_uuid() primary key,
  group_id     uuid not null references groups(id) on delete cascade,
  sender_id    uuid not null references auth.users(id) on delete cascade,
  sender_name  text not null,
  type         text not null check (type in ('text','fd','alert','doc')),
  text         text,
  payload      jsonb,
  created_at   timestamptz default now()
);

create index if not exists gfm_group_idx on group_finance_messages(group_id);
create index if not exists gfm_created_idx on group_finance_messages(group_id, created_at desc);

alter table group_finance_messages enable row level security;

-- Members of the group can read messages
create policy "Group members can read messages"
  on group_finance_messages for select
  using (
    exists (
      select 1 from group_members
      where group_members.group_id = group_finance_messages.group_id
      and group_members.user_id = auth.uid()
    )
  );

-- Members of the group can insert messages
create policy "Group members can send messages"
  on group_finance_messages for insert
  with check (
    auth.uid() = sender_id
    and exists (
      select 1 from group_members
      where group_members.group_id = group_finance_messages.group_id
      and group_members.user_id = auth.uid()
    )
  );
```

### 3b — Shared deposits table (for sharing FD cards between members)
```sql
create table if not exists group_shared_deposits (
  id           uuid default gen_random_uuid() primary key,
  group_id     uuid not null references groups(id) on delete cascade,
  shared_by    uuid not null references auth.users(id) on delete cascade,
  deposit_data jsonb not null,
  shared_at    timestamptz default now()
);

alter table group_shared_deposits enable row level security;

create policy "Group members can view shared deposits"
  on group_shared_deposits for select
  using (
    exists (
      select 1 from group_members
      where group_members.group_id = group_shared_deposits.group_id
      and group_members.user_id = auth.uid()
    )
  );

create policy "Group members can share deposits"
  on group_shared_deposits for insert
  with check (
    auth.uid() = shared_by
    and exists (
      select 1 from group_members
      where group_members.group_id = group_shared_deposits.group_id
      and group_members.user_id = auth.uid()
    )
  );
```

### 3c — NOTE on table names
If your existing groups table is NOT named `groups` or group membership
is NOT in `group_members`, adjust the foreign key references above to match
your actual table names. Check `src/types/groups.ts` or search for
`supabase.from('` in the codebase to find the real table names.

