## STEP 4 — TypeScript types

Create a new file `src/types/groupChat.ts`:

```ts
export type MessageType = 'text' | 'fd' | 'alert' | 'doc'

export interface FDPayload {
  id: string
  bank: string
  type: string
  deposit: number | ''
  maturityDate: string
  roi: number | ''
  maturityAmt: number | ''
}

export interface AlertPayload {
  title: string
  date: string
  amount: number
  bank: string
  daysLeft: number
}

export interface DocPayload {
  name: string
  size: string
  type: string
  url?: string
}

export interface GroupFinanceMessage {
  id: string
  group_id: string
  sender_id: string
  sender_name: string
  type: MessageType
  text: string
  payload?: {
    fd?: FDPayload
    alert?: AlertPayload
    doc?: DocPayload
  }
  created_at: string
}

export interface GroupMemberProfile {
  id: string
  name: string
  role: 'owner' | 'member'
  avatar: string
  color: string
}
```

