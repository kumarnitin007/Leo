## STEP 9 — Member profile mapping

When passing members to the chat component, map your existing Group
member objects to `GroupMemberProfile`. Add this helper near the
Groups section component:

```tsx
const MEMBER_COLORS = [
  '#6366F1', '#10B981', '#F97316', '#8B5CF6',
  '#EF4444', '#F59E0B', '#06B6D4', '#EC4899',
]

function mapMemberToProfile(member: any, index: number): GroupMemberProfile {
  const name = member.displayName || member.name || member.email || 'Member'
  return {
    id:     member.userId || member.id,
    name,
    role:   member.role === 'owner' ? 'owner' : 'member',
    avatar: name.slice(0, 2).toUpperCase(),
    color:  MEMBER_COLORS[index % MEMBER_COLORS.length],
  }
}
```

