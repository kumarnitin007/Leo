export default function GroupFinanceChat({
  supabase,
  groupId,
  groupName,
  currentUser,
  members,
  userDeposits = [],
}: GroupFinanceChatProps) {
```

Then inside the component:
- Replace `ME` with `currentUser`
- Replace `MEMBERS` with `members`
- Replace `MY_DEPOSITS` with `userDeposits`
- Replace `INIT_MESSAGES` with `[]` (messages come from Supabase now — see Step 6)
